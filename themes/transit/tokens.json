{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Transit 6.0-inspired theme — bigger, bolder, rounder. Inspired by https://blog.transitapp.com/six-o/ (not official Transit brand assets).",
  "meta": {
    "name": { "$value": "transit", "$type": "string" },
    "label": { "$value": "Transit", "$type": "string" },
    "description": {
      "$value": "Bold route colours, bubbly ETA cards, midnight neon dark mode. Typography uses Plus Jakarta Sans as a Puffin Transit substitute.",
      "$type": "string"
    }
  },
  "font": {
    "family": {
      "sans": {
        "$value": "'Plus Jakarta Sans', ui-sans-serif, system-ui, -apple-system, 'Segoe UI', sans-serif",
        "$type": "fontFamily",
        "$description": "Open substitute for Puffin Transit (proprietary). Load via Google Fonts."
      },
      "display": {
        "$value": "'Plus Jakarta Sans', ui-sans-serif, system-ui, sans-serif",
        "$type": "fontFamily",
        "$description": "Large ETA / hero numbers"
      },
      "mono": {
        "$value": "ui-monospace, 'SF Mono', Menlo, Consolas, monospace",
        "$type": "fontFamily"
      }
    }
  },
  "radius": {
    "card": { "$value": "20px", "$type": "dimension", "$description": "ETA card corners" },
    "button": { "$value": "14px", "$type": "dimension" },
    "chip": { "$value": "9999px", "$type": "dimension" }
  },
  "color": {
    "brand": {
      "primary": {
        "$value": "#1BD974",
        "$type": "color",
        "$description": "Transit signature green — friendly, bright, car-free energy"
      },
      "primary-hover": { "$value": "#14C266", "$type": "color" },
      "primary-foreground": { "$value": "#052E16", "$type": "color" },
      "secondary": { "$value": "#0F172A", "$type": "color" },
      "secondary-foreground": { "$value": "#F8FAFC", "$type": "color" }
    },
    "light": {
      "background": { "$value": "#FFFFFF", "$type": "color" },
      "background-subtle": { "$value": "#F4F7FA", "$type": "color" },
      "foreground": { "$value": "#0F172A", "$type": "color" },
      "foreground-muted": { "$value": "#64748B", "$type": "color" },
      "card": { "$value": "#FFFFFF", "$type": "color" },
      "card-foreground": { "$value": "#0F172A", "$type": "color" },
      "border": { "$value": "#E2E8F0", "$type": "color" },
      "border-strong": { "$value": "#CBD5E1", "$type": "color" },
      "ring": { "$value": "#1BD974", "$type": "color" }
    },
    "dark": {
      "background": { "$value": "#0A0E17", "$type": "color", "$description": "Neon Dark Mode midnight base" },
      "background-subtle": { "$value": "#111827", "$type": "color" },
      "foreground": { "$value": "#F1F5F9", "$type": "color" },
      "foreground-muted": { "$value": "#94A3B8", "$type": "color" },
      "card": { "$value": "#151C2C", "$type": "color" },
      "card-foreground": { "$value": "#F8FAFC", "$type": "color" },
      "border": { "$value": "#1E293B", "$type": "color" },
      "border-strong": { "$value": "#334155", "$type": "color" },
      "ring": { "$value": "#34D399", "$type": "color" },
      "neon-glow": { "$value": "0 0 24px rgb(27 217 116 / 0.35)", "$type": "shadow" }
    },
    "semantic": {
      "success": { "$value": "#22C55E", "$type": "color" },
      "warning": { "$value": "#FFA900", "$type": "color", "$description": "Transit partner alert yellow" },
      "destructive": { "$value": "#E51304", "$type": "color", "$description": "Transit partner emergency red" },
      "info": { "$value": "#3B82F6", "$type": "color" }
    },
    "route": {
      "red": { "$value": "#E51304", "$type": "color" },
      "orange": { "$value": "#F97316", "$type": "color" },
      "yellow": { "$value": "#FFA900", "$type": "color" },
      "green": { "$value": "#22C55E", "$type": "color" },
      "teal": { "$value": "#14B8A6", "$type": "color" },
      "blue": { "$value": "#2563EB", "$type": "color" },
      "indigo": { "$value": "#6366F1", "$type": "color" },
      "purple": { "$value": "#9333EA", "$type": "color" },
      "pink": { "$value": "#EC4899", "$type": "color" },
      "gray": { "$value": "#64748B", "$type": "color" }
    }
  },
  "component": {
    "eta-card": {
      "min-height": { "$value": "120px", "$type": "dimension" },
      "padding-x": { "$value": "20px", "$type": "dimension" },
      "padding-y": { "$value": "16px", "$type": "dimension" },
      "time-size": { "$value": "60px", "$type": "dimension", "$description": "Transit 6.0 supersized departure time" },
      "time-weight": { "$value": "800", "$type": "fontWeight" },
      "header-height": { "$value": "44px", "$type": "dimension" }
    },
    "button": {
      "height-sm": { "$value": "36px", "$type": "dimension" },
      "height-md": { "$value": "44px", "$type": "dimension" },
      "height-lg": { "$value": "52px", "$type": "dimension" },
      "padding-x": { "$value": "20px", "$type": "dimension" }
    },
    "nav": {
      "height": { "$value": "56px", "$type": "dimension" }
    }
  }
}
